#define EMOJI_FRUIT "\xF0\x9F\x8D\x8E" /* рҹҚҺ */
#define BLANK "  "                     /* 2 espaГ§os apagam 1 emoji */

#define STEP_X 2
#define STEP_Y 1

typedef struct Node
{
    int x, y;
    struct Node *next;
    struct Node *prev;
} Node;

typedef struct
{
    int x, y;
} Fruit;

static Node *head = NULL;
static Node *tail = NULL;
static Fruit fruits[FRUIT_COUNT];
static int dirX = 0, dirY = 0;
static int score = 0;
static int gameOver = 0;
static HANDLE hConsole;

/* ================= UTIL ================= */

static void setColor(int c) { SetConsoleTextAttribute(hConsole, c); }

static void gotoxy(int x, int y)
{
    COORD c = {(SHORT)x, (SHORT)y};
    SetConsoleCursorPosition(hConsole, c);
}

static void hideCursor(void)
{
    CONSOLE_CURSOR_INFO ci = {1, FALSE};
    SetConsoleCursorInfo(hConsole, &ci);
}

/* ================= LISTA ================= */

static void insert_head(int x, int y)
{
    Node *n = (Node *)malloc(sizeof(Node));
    if (!n)
        return;
    n->x = x;
    n->y = y;
    n->next = head;
    n->prev = NULL;
    if (head)
        head->prev = n;
    head = n;
    if (!tail)
        tail = n;
}

static void remove_tail(void)
{
    if (!tail)
        return;
    Node *tmp = tail;
    tail = tail->prev;
    if (tail)
        tail->next = NULL;
    else
        head = NULL;
    free(tmp);
}

static void free_snake(void)
{
    Node *cur = head;
    while (cur)
    {
        Node *nxt = cur->next;
        free(cur);
        cur = nxt;
    }
    head = tail = NULL;
}

/* ================= DETECCAO ================= */

static int collision(int x, int y)
{
    if (x < STEP_X || x >= WIDTH || y <= TOP_OFFSET || y >= HEIGHT + TOP_OFFSET)
        return 1;
    for (Node *t = head->next; t; t = t->next)
        if (t->x == x && t->y == y)
            return 1;
    return 0;
}

static int snake_on_position(int x, int y)
{
    for (Node *t = head; t; t = t->next)
        if (t->x == x && t->y == y)
            return 1;
    return 0;
}

/* ================= RENDERIZACAO ================= */

static void draw_border(void)
{
    setColor(9);
    for (int i = 0; i <= WIDTH; i++)
    {
        gotoxy(i, TOP_OFFSET);
        printf("_");
        gotoxy(i, HEIGHT + TOP_OFFSET);
        printf("_");
    }
    for (int i = TOP_OFFSET; i <= HEIGHT + TOP_OFFSET; i++)
    {
        gotoxy(0, i);
        printf("|");
        gotoxy(WIDTH, i);
        printf("|");
    }
    setColor(7);
}

static void draw_score(void)
{
    setColor(14);
    gotoxy(2, 0);
    printf("рқ•Ҡв„•рқ”ёрқ•Ӯрқ”ј");
    printf("\n рқ•Ҡрқ•”рқ• рқ•Јрқ•–: %d   ", score);
    setColor(7);
}

static void draw_snake(void)
{
    for (Node *t = head; t; t = t->next)
    {
        gotoxy(t->x, t->y);
        printf(EMOJI_SNAKE);
    }
}

/* ================= FRUTAS ================= */

static void draw_fruit(int i)
{
    gotoxy(fruits[i].x, fruits[i].y);
    printf(EMOJI_FRUIT);
}

static void generate_fruit(int i)
{
    do
    {
        int col = rand() % ((WIDTH - 2) / STEP_X);
        fruits[i].x = col * STEP_X + STEP_X;
        fruits[i].y = rand() % (HEIGHT - 1) + 1 + TOP_OFFSET;
    } while (snake_on_position(fruits[i].x, fruits[i].y));
    draw_fruit(i);
}

static void init_fruits(void)
{
    for (int i = 0; i < FRUIT_COUNT; i++)
        generate_fruit(i);
}

/* ================= INPUT ================= */

static void input(void)
{
    if (!_kbhit())
        return;
    int key = _getch();
    if (key != 224)
        return;
    key = _getch();
    switch (key)
    {
    case 72:
        if (dirY != STEP_Y)
        {
            dirX = 0;
            dirY = -STEP_Y;
        }
        break;
    case 80:
        if (dirY != -STEP_Y)
        {
            dirX = 0;
            dirY = STEP_Y;
        }
        break;
    case 75:
        if (dirX != STEP_X)
        {
            dirX = -STEP_X;
            dirY = 0;
        }
        break;
    case 77:
        if (dirX != -STEP_X)
        {
            dirX = STEP_X;
            dirY = 0;
        }
        break;
    }
}

/* ================= LOGICA ================= */

static void update(void)
{
    if (!dirX && !dirY)
        return;

    int newX = head->x + dirX;
    int newY = head->y + dirY;

    if (collision(newX, newY))
    {
        gameOver = 1;
        return;
    }

    int ateFruit = 0;
    for (int i = 0; i < FRUIT_COUNT; i++)
    {
        if (newX == fruits[i].x && newY == fruits[i].y)
        {
            score += 10;
            ateFruit = 1;
            generate_fruit(i);
            break;
        }
    }

    if (!ateFruit)
    {
        gotoxy(tail->x, tail->y);
        printf(BLANK);
        remove_tail();
    }

    insert_head(newX, newY);
    draw_snake();
    for (int i = 0; i < FRUIT_COUNT; i++)
        draw_fruit(i);
    draw_score();
}

/* ================= RESET ================= */

static void reset_game(void)
{
    free_snake();
    dirX = 0;
    dirY = 0;
    score = 0;
    gameOver = 0;
    system("cls");
    int startX = (WIDTH / 2 / STEP_X) * STEP_X;
    insert_head(startX, HEIGHT / 2 + TOP_OFFSET);
    draw_border();
    init_fruits();
    draw_snake();
    draw_score();
}

