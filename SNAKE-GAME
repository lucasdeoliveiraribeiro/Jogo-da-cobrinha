{
    SetConsoleOutputCP(65001);
    SetConsoleCP(65001);

    hConsole = GetStdHandle(STD_OUTPUT_HANDLE);
    srand((unsigned)time(NULL));
    hideCursor();

    int quit = 0;

    while (!quit)
    {
        if (show_menu() == 1)
        {
            quit = 1;
            break;
        }

        /* Partida */
        do
        {
            reset_game();
            while (!gameOver)
            {
                input();
                update();
                Sleep(SPEED);
