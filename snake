/* Retorna 0 se deve jogar, 1 se deve sair */
static int show_menu(void)
{
    int selected = 0;
    draw_menu(selected);

    while (1)
    {
        int key = _getch();

        if (key == 224)
        {
            key = _getch();
            if (key == 72)
            { /* seta cima  */
                selected = (selected - 1 + MENU_ITEMS) % MENU_ITEMS;
                draw_menu(selected);
            }
            if (key == 80)
            { /* seta baixo */
                selected = (selected + 1) % MENU_ITEMS;
                draw_menu(selected);
            }
        }

        if (key == 13)
        { /* ENTER */
            if (selected == 0)
                return 0; /* Jogar     */
            if (selected == 1)
            {
                show_about();
                draw_menu(selected);
            }
            if (selected == 2)
            {
                show_about_me();
                draw_menu(selected);
            }
            if (selected == 3)
                return 1; /* Sair      */
        }

        if (key == 27)
            return 1; /* ESC = sair */
    }
}

