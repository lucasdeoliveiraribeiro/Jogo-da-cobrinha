/* Utilitario: imprime texto quebrado em linhas de max 'maxcols' caracteres */
static void print_wrapped(int x, int *row, const char *text, int maxcols)
{
    char buf[256];
    int len = 0;
    const char *p = text;

    while (*p)
    {
        /* Encontra o fim da proxima palavra */
        const char *word_end = p;
        while (*word_end && *word_end != ' ')
            word_end++;

        int word_len = (int)(word_end - p);

        /* Se a palavra nao cabe na linha atual, quebra */
        if (len > 0 && len + 1 + word_len > maxcols)
        {
            buf[len] = '\0';
            gotoxy(x, *row);
            printf("%s", buf);
            (*row)++;
            len = 0;
        }

        /* Adiciona espaco separador se nao for inicio da linha */
        if (len > 0)
            buf[len++] = ' ';

        /* Copia a palavra */
        for (int i = 0; i < word_len && len < 254; i++)
            buf[len++] = p[i];

        p = word_end;
        while (*p == ' ')
            p++; /* pula espacos */
    }

    /* Imprime o que sobrou */
    if (len > 0)
    {
        buf[len] = '\0';
        gotoxy(x, *row);
        printf("%s", buf);
        (*row)++;
    }
}

